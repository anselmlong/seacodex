{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seacodex.local/contracts/analyst-summary.schema.json",
  "title": "Analyst Summary",
  "type": "object",
  "required": [
    "top_segment",
    "recommended_action",
    "winning_message_variant",
    "backlash_risk_score",
    "supporting_node_ids",
    "confidence"
  ],
  "properties": {
    "top_segment": { "type": "string" },
    "recommended_action": {
      "type": "string",
      "enum": ["target", "avoid", "test"]
    },
    "winning_message_variant": { "type": "string" },
    "backlash_risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "supporting_node_ids": {
      "type": "array",
      "items": { "type": ["string", "integer"] }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "narrative": { "type": "string" }
  },
  "additionalProperties": false
}

